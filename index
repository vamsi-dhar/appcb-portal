    const saved=lsRaw('appcb7_notes_'+ro.id,'');
    body.innerHTML=`<div class="section-hd">Notes &amp; Other Info — ${_panelRO}</div>
      <div style="font-size:12px;color:var(--smoke);margin-bottom:10px;line-height:1.6">General notes, pending actions, inspection records, complaints…</div>
      <textarea class="editable-area" id="editTA" style="min-height:180px" placeholder="Add notes here…">${saved}</textarea>
      <div class="save-row"><div class="saved-notice" id="savedNote">✓ Saved</div><button class="save-btn" onclick="saveTab('notes')">💾 Save</button></div>`;
  }
}

function saveTab(tab){
  const val=document.getElementById('editTA')?.value||'';
  const ro=RO_DATA[_panelRO];if(!ro)return;
  lsRawSet('appcb7_'+tab+'_'+ro.id,val);
  const n=document.getElementById('savedNote');
  if(n){n.classList.add('show');setTimeout(()=>n.classList.remove('show'),2000)}
}

/* ══════════════════════════════════════════════════
   GLOBAL LOCK ENGINE
   3 methods: Password · Email OTP · Face ID
   Locks: add/delete/rename/upload (editing actions)
   Viewing always works — lock is edit-only guard
══════════════════════════════════════════════════ */
const GL={
  isLocked(){ return LS.get('gl_locked',false) },
  getMethod(){ return LS.get('gl_method',null) }, // 'pwd'|'otp'|'face'
  getPwdHash(){ return LS.get('gl_pwd_hash',null) },
  setPwdHash(h){ LS.set('gl_pwd_hash',h) },
  getOtpCfg(){ return LS.get('gl_otp_cfg',null) },
  setOtpCfg(c){ LS.set('gl_otp_cfg',c) },
  getFaceData(){ return LS.get('gl_face_data',null) },
  setFaceData(d){ LS.set('gl_face_data',d) },
  lock(method){ LS.set('gl_locked',true); LS.set('gl_method',method); applyGLock(true) },
  unlock(){ LS.set('gl_locked',false); applyGLock(false) },
  clearAll(){ ['gl_locked','gl_method','gl_pwd_hash','gl_otp_cfg','gl_face_data'].forEach(k=>LS.del(k)); applyGLock(false) }
};

function applyGLock(locked){
  document.body.classList.toggle('glocked', locked);
  document.getElementById('gLockBanner').classList.toggle('show', locked);
  const btn=document.getElementById('gLockBtn');
  if(locked){ btn.textContent='🔒 Locked'; btn.classList.add('locked'); }
  else { btn.textContent='🔓 Lock Editing'; btn.classList.remove('locked'); }
}

// Called on every edit action — if locked, show unlock dialog and return false
function editGuard(){
  if(GL.isLocked()){ gUnlockPrompt(); return false; }
  return true;
}

/* ── Startup ── */
(function initGLock(){
  if(GL.isLocked()) applyGLock(true);
})();

/* ── Main toggle button ── */
let _selMethod=null;
function gLockToggle(){
  if(GL.isLocked()){ gUnlockPrompt(); return; }
  // Already configured? Just re-lock with same method
  const m=GL.getMethod();
  if(m==='pwd' && GL.getPwdHash()){ showDlg('gPwdSetDlg'); return; }
  if(m==='otp' && GL.getOtpCfg()){ GL.lock('otp'); return; }
  if(m==='face' && GL.getFaceData()){ GL.lock('face'); return; }
  // First time — show method picker
  _selMethod=null;
  document.querySelectorAll('.lk-method-card').forEach(c=>c.classList.remove('sel'));
  showDlg('gMethodDlg');
}

function selectMethod(m){
  _selMethod=m;
  document.querySelectorAll('.lk-method-card').forEach(c=>c.classList.remove('sel'));
  document.getElementById('mc-'+m).classList.add('sel');
}

function proceedSetup(){
  if(!_selMethod){ alert('Please choose a method.'); return; }
  closeDlg('gMethodDlg');
  if(_selMethod==='pwd') showDlg('gPwdSetDlg');
  else if(_selMethod==='otp') showDlg('gOtpSetDlg');
  else gFaceSetOpen();
}

/* ── PASSWORD method ── */
async function gPwdSetConfirm(){
  const p1=document.getElementById('gPw1').value;
  const p2=document.getElementById('gPw2').value;
  if(!p1||p1.length<4){ alert('Minimum 4 characters.'); return; }
  if(p1!==p2){ alert('Passwords do not match.'); return; }
  GL.setPwdHash(await sha256(p1));
  document.getElementById('gPw1').value='';
  document.getElementById('gPw2').value='';
  closeDlg('gPwdSetDlg');
  GL.lock('pwd');
}

function gUnlockPrompt(){
  const m=GL.getMethod();
  if(m==='pwd') showDlg('gPwdUnlDlg');
  else if(m==='otp'){ showDlg('gOtpUnlDlg'); gSendOtp(); }
  else if(m==='face') gFaceUnlOpen();
  else { GL.unlock(); } // no method set, just unlock
}

async function gPwdUnlConfirm(){
  const p=document.getElementById('gPwUn').value;
  const h=await sha256(p);
  if(h===GL.getPwdHash()){
    document.getElementById('gPwUn').value='';
    closeDlg('gPwdUnlDlg');
    GL.unlock();
  } else {
    document.getElementById('gPwUn').value='';
    alert('❌ Wrong password. Try again.');
  }
}

/* ── OTP method ── */
let _curOtp='';
function gOtpSetConfirm(){
  const pub=document.getElementById('gEjsPub').value.trim();
  const svc=document.getElementById('gEjsSvc').value.trim();
  const tpl=document.getElementById('gEjsTpl').value.trim();
  const email=document.getElementById('gEjsEmail').value.trim();
  if(!pub||!svc||!tpl||!email){ alert('Fill all fields.'); return; }
  GL.setOtpCfg({pub,svc,tpl,email});
  ['gEjsPub','gEjsSvc','gEjsTpl','gEjsEmail'].forEach(id=>document.getElementById(id).value='');
  closeDlg('gOtpSetDlg');
  GL.lock('otp');
}

async function gSendOtp(){
  const cfg=GL.getOtpCfg(); if(!cfg) return;
  _curOtp=String(Math.floor(100000+Math.random()*900000));
  document.getElementById('gOtpMsg').textContent='Sending OTP to '+cfg.email+'…';
  document.getElementById('gOtpIn').value='';
  try{
    await new Promise((res,rej)=>{
      const s=document.createElement('script');
      s.onload=res; s.onerror=rej;
      s.src='https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js';
      if(window.emailjs){res();s.remove();return}
      document.head.appendChild(s);
    });
    await emailjs.send(cfg.svc, cfg.tpl, {otp:_curOtp, to_email:cfg.email}, cfg.pub);
    document.getElementById('gOtpMsg').textContent='OTP sent to '+cfg.email+'. Check your inbox.';
  } catch(e){
    document.getElementById('gOtpMsg').textContent='Send failed. Check EmailJS config.';
    console.error(e);
  }
}

function gOtpUnlConfirm(){
  const entered=document.getElementById('gOtpIn').value.trim();
  if(entered===_curOtp && _curOtp){
    _curOtp='';
    document.getElementById('gOtpIn').value='';
    closeDlg('gOtpUnlDlg');
    GL.unlock();
  } else {
    alert('❌ Wrong OTP. Try again or resend.');
  }
}

/* ── FACE ID method ── */
let _faceStream=null, _faceDescriptor=null;

function gFaceSetOpen(){
  showDlg('gFaceSetDlg');
  document.getElementById('gFaceBar').style.width='0%';
  document.getElementById('gFaceStatus').textContent='Camera starting…';
  document.getElementById('gFaceCapBtn').disabled=true;
  _faceDescriptor=null;
  navigator.mediaDevices.getUserMedia({video:{facingMode:'user',width:320,height:320}})
    .then(stream=>{
      _faceStream=stream;
      const v=document.getElementById('gFaceVid');
      v.srcObject=stream; v.play();
      document.getElementById('gFaceStatus').textContent='Position your face in the circle, then click Capture.';
      document.getElementById('gFaceCapBtn').disabled=false;
    })
    .catch(()=>{ document.getElementById('gFaceStatus').textContent='Camera access denied.'; });
}

async function gFaceCapture(mode){
  const vid=document.getElementById('gFaceVid');
  const status=document.getElementById('gFaceStatus');
  const bar=document.getElementById('gFaceBar');
  const overlay=document.getElementById('gFaceOverlay');
  overlay.classList.add('scanning');
  status.textContent='Capturing…';
  const frames=[];
  for(let i=0;i<3;i++){
    bar.style.width=((i+1)/3*100)+'%';
    const desc=captureFrame(vid);
    frames.push(desc);
    await sleep(300);
  }
  // Average the 3 frames
  const avg=frames[0].map((_,j)=>frames.reduce((s,f)=>s+f[j],0)/frames.length);
  GL.setFaceData(avg);
  overlay.classList.remove('scanning');
  status.textContent='✅ Face registered! Locking now…';
  bar.style.width='100%';
  await sleep(700);
  gFaceStopStream();
  closeDlg('gFaceSetDlg');
  GL.lock('face');
}

function gFaceUnlOpen(){
  showDlg('gFaceUnlDlg');
  document.getElementById('gFaceUnlBar').style.width='0%';
  document.getElementById('gFaceUnlStatus').textContent='Camera starting…';
  document.getElementById('gFaceUnlBtn').disabled=true;
  navigator.mediaDevices.getUserMedia({video:{facingMode:'user',width:320,height:320}})
    .then(stream=>{
      _faceStream=stream;
      const v=document.getElementById('gFaceUnlVid');
      v.srcObject=stream; v.play();
      document.getElementById('gFaceUnlStatus').textContent='Look at the camera, then click Scan Face.';
      document.getElementById('gFaceUnlBtn').disabled=false;
    })
    .catch(()=>{ document.getElementById('gFaceUnlStatus').textContent='Camera access denied.'; });
}

async function gFaceScan(){
  const vid=document.getElementById('gFaceUnlVid');
  const status=document.getElementById('gFaceUnlStatus');
  const bar=document.getElementById('gFaceUnlBar');
  const overlay=document.getElementById('gFaceUnlOverlay');
  const stored=GL.getFaceData(); if(!stored){ status.textContent='No face registered.'; return; }
  overlay.classList.add('scanning');
  status.textContent='Scanning…';
  const frames=[];
  for(let i=0;i<4;i++){
    bar.style.width=((i+1)/4*100)+'%';
    frames.push(captureFrame(vid));
    await sleep(250);
  }
  const avg=frames[0].map((_,j)=>frames.reduce((s,f)=>s+f[j],0)/frames.length);
  const sim=cosineSim(avg,stored);
  overlay.classList.remove('scanning');
  if(sim>0.92){
    status.textContent='✅ Matched! Unlocking…';
    bar.style.width='100%';
    await sleep(600);
    gFaceStopStream();
    closeDlg('gFaceUnlDlg');
    GL.unlock();
  } else {
    status.textContent='❌ Face not recognised ('+Math.round(sim*100)+'% match). Try again.';
    bar.style.width='0%';
    overlay.classList.remove('scanning');
  }
}

function gFaceCancel(mode){
  gFaceStopStream();
  closeDlg(mode==='set'?'gFaceSetDlg':'gFaceUnlDlg');
}
function gFaceStopStream(){
  if(_faceStream){_faceStream.getTracks().forEach(t=>t.stop());_faceStream=null;}
}

/* Face helper: capture 20×20 pixel luminance descriptor */
function captureFrame(vid){
  const c=document.createElement('canvas'); c.width=20; c.height=20;
  c.getContext('2d').drawImage(vid,0,0,20,20);
  const d=c.getContext('2d').getImageData(0,0,20,20).data;
  const lum=[];
  for(let i=0;i<d.length;i+=4) lum.push((d[i]*.299+d[i+1]*.587+d[i+2]*.114)/255);
  return lum;
}
function cosineSim(a,b){
  let dot=0,na=0,nb=0;
  for(let i=0;i<a.length;i++){dot+=a[i]*b[i];na+=a[i]*a[i];nb+=b[i]*b[i];}
  return dot/(Math.sqrt(na)*Math.sqrt(nb)||1);
}
function sleep(ms){return new Promise(r=>setTimeout(r,ms))}

/* ── Reset lock ── */
function gResetLock(){
  if(!confirm('Remove the global lock completely? You will need to set it up again.')) return;
  ['gPwdUnlDlg','gOtpUnlDlg','gFaceUnlDlg'].forEach(id=>{ const el=document.getElementById(id); if(el.classList.contains('show')) closeDlg(id); });
  gFaceStopStream();
  GL.clearAll();
}

