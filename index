const DIST_TELUGU={"Srikakulam":"శ్రీకాకుళం","Parvathipuram Manyam":"పార్వతీపురం మన్యం","Vizianagaram":"విజయనగరం","Alluri Sitharama Raju":"అల్లూరి సీతారామ రాజు","Polavaram":"పోలవరం","Visakhapatnam":"విశాఖపట్నం","Anakapalli":"అనకాపల్లి","East Godavari":"తూర్పు గోదావరి","Konaseema":"కోనసీమ","Kakinada":"కాకినాడ","Eluru":"ఏలూరు","West Godavari":"పశ్చిమ గోదావరి","NTR":"ఎన్.టి.ఆర్ జిల్లా","Krishna":"కృష్ణా","Guntur":"గుంటూరు","Palnadu":"పల్నాడు","Prakasam":"ప్రకాశం","Bapatla":"బాపట్ల","Markapuram":"మార్కాపురం","SPSR Nellore":"శ్రీ పొట్టి శ్రీరాములు నెల్లూరు","Tirupati":"తిరుపతి","Chittoor":"చిత్తూరు","Kurnool":"కర్నూలు","Nandyal":"నంద్యాల","YSR Kadapa":"వై.యస్.ఆర్. కడప","Annamayya":"అన్నమయ్య","Anantapur":"అనంతపురం","Sri Sathya Sai":"శ్రీ సత్య సాయి"};

// Map state
let mapReady=false, leafMap, geojsonLayer, markersLayer;
let activeDistLayer=null, showDistricts=true, showRO=true;
let _panelRO=null, currentTab='overview';
let legOpen=true;

function getROForDistrict(raw){
  const k=raw.toLowerCase().replace(/[^a-z0-9]/g,'');
  if(DIST2RO[k])return DIST2RO[k];
  for(const[dk,ro]of Object.entries(DIST2RO))if(dk.includes(k)||k.includes(dk))return ro;
  return null;
}
function getROColor(raw){const ro=getROForDistrict(raw);return ro?RO_DATA[ro].color:'#a0b8b0'}
function hexToRgb(h){return{r:parseInt(h.slice(1,3),16),g:parseInt(h.slice(3,5),16),b:parseInt(h.slice(5,7),16)}}
function lighten(h,a=30){const{r,g,b}=hexToRgb(h);return`rgb(${Math.min(255,r+a)},${Math.min(255,g+a)},${Math.min(255,b+a)})`}
function getDistName(p){return p.district||p.District||p.DISTRICT||p.NAME_2||p.dtname||p.name||'Unknown'}

function styleDefault(feat){const c=getROColor(normDistName(feat.properties));return{fillColor:c,weight:2,color:'rgba(255,255,255,0.85)',fillOpacity:0.75}}
function styleHover(feat){const c=getROColor(normDistName(feat.properties));return{fillColor:lighten(c,22),weight:3,color:'#fff',fillOpacity:0.95}}
function styleActive(){return{fillColor:'rgba(255,255,255,0.5)',weight:3.5,color:'#1a5e38',fillOpacity:0.45}}

function openMap(){
  document.getElementById('mapScreen').classList.add('show');
  if(!mapReady){initLeafMap();mapReady=true}
}
function closeMap(){document.getElementById('mapScreen').classList.remove('show')}

// Normalise any GeoJSON district name to our standard RO-matching name
function normDistName(props){
  const raw = props.district||props.District||props.DISTRICT||props.dtname||props.NAME_2||props.name||props.NAME||'';
  const key = raw.toLowerCase().trim().replace(/\s+/g,' ');
  return DIST_NAME_MAP[key] || raw;
}

function buildGeoLayer(geojson){
  geojsonLayer=L.geoJSON(geojson,{
    style:styleDefault,
    onEachFeature(feat,layer){
      const name=normDistName(feat.properties);
      const ro=getROForDistrict(name);
      layer.on({
        mouseover(e){
          if(layer!==activeDistLayer)layer.setStyle(styleHover(feat));
          layer.bindTooltip(
            `<b>${name}</b>${ro?'<br><span style="color:'+RO_DATA[ro].color+';font-size:11px">'+ro+'</span>':''}`,
            {permanent:false,direction:'auto',className:'ap-tip',offset:[0,-4]}
          ).openTooltip();
        },
        mouseout(){if(layer!==activeDistLayer)layer.setStyle(styleDefault(feat));layer.closeTooltip()},
        click(e){
          if(activeDistLayer&&activeDistLayer!==layer){
            const prevFeat=activeDistLayer.feature;
            activeDistLayer.setStyle(styleDefault(prevFeat||feat));
          }
          layer.setStyle(styleActive());activeDistLayer=layer;
          L.DomEvent.stopPropagation(e);
          ro?openROPanel(ro):openDistPanel(name);
        }
      });
    }
  }).addTo(leafMap);

  const bounds=geojsonLayer.getBounds();
  if(bounds.isValid()){
    leafMap.fitBounds(bounds,{padding:[24,24]});
    leafMap.setMaxBounds(bounds.pad(0.12));
  }
}

function showMapLoader(msg){
  let el=document.getElementById('mapLoader');
  if(!el){
    el=document.createElement('div');
    el.id='mapLoader';
    el.style.cssText='position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(232,245,238,0.92);z-index:1000;gap:14px;font-family:DM Sans,sans-serif;';
    el.innerHTML='<div style="font-size:38px">🗺️</div><div id="mapLoaderMsg" style="font-size:14px;color:#1a5e38;font-weight:600"></div>';
    document.getElementById('theLeafMap').parentElement.style.position='relative';
    document.getElementById('theLeafMap').parentElement.appendChild(el);
  }
  document.getElementById('mapLoaderMsg').textContent=msg;
}
function hideMapLoader(){const el=document.getElementById('mapLoader');if(el)el.remove();}

async function initLeafMap(){
  leafMap=L.map('theLeafMap',{center:[15.9,79.7],zoom:7,zoomControl:true,attributionControl:false});
  L.control.attribution({position:'bottomright',prefix:false}).addTo(leafMap);

  showMapLoader('Loading AP district boundaries…');

  // Try multiple reliable GeoJSON sources (real official boundaries)
  const GEOJSON_URLS=[
    // jsDelivr (CDN for GitHub) — datameet India maps — most accurate AP districts
    'https://cdn.jsdelivr.net/gh/datameet/maps@master/Districts/Andhra_Pradesh.geojson',
    // udit-001 india-maps-data (also on jsDelivr)
    'https://cdn.jsdelivr.net/gh/udit-001/india-maps-data@main/geojson/states/andhra-pradesh.geojson',
    // raw GitHub fallback
    'https://raw.githubusercontent.com/datameet/maps/master/Districts/Andhra_Pradesh.geojson',
  ];

  let loaded=false;
  for(const url of GEOJSON_URLS){
    try{
      showMapLoader('Fetching district map…');
      const resp=await fetch(url,{cache:'force-cache'});
      if(!resp.ok)continue;
      const data=await resp.json();
      if(!data||!data.features||!data.features.length)continue;
      hideMapLoader();
      buildGeoLayer(data);
      loaded=true;
      break;
    }catch(e){console.warn('GeoJSON source failed:',url,e)}
  }

  if(!loaded){
    hideMapLoader();
    // Show friendly error on the map itself
    const errDiv=document.createElement('div');
    errDiv.style.cssText='position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;background:rgba(232,245,238,.95);z-index:1000;font-family:DM Sans,sans-serif;gap:10px;padding:24px;text-align:center;';
    errDiv.innerHTML=`<div style="font-size:42px">🌐</div>
      <div style="font-size:15px;font-weight:700;color:#1a5e38">Map requires internet</div>
      <div style="font-size:13px;color:#6b6b6b;max-width:300px">District boundaries are loaded from a public GeoJSON source. Please check your connection and reopen the map.</div>
      <button onclick="document.getElementById('mapLoader2')?.remove();mapReady=false;closeMap();" style="margin-top:8px;padding:9px 22px;border-radius:20px;background:#1a5e38;color:#fff;border:none;cursor:pointer;font-size:13px">Close Map</button>`;
    errDiv.id='mapLoader2';
    document.getElementById('theLeafMap').parentElement.appendChild(errDiv);
  }

  addROMarkers();
  buildLegend();

  leafMap.on('click',()=>{
    if(activeDistLayer){
      const f=activeDistLayer.feature;
      activeDistLayer.setStyle(styleDefault(f||{properties:{}}));
      activeDistLayer=null;
    }
    closePanel();
  });
}

function addROMarkers(){
  markersLayer=L.layerGroup().addTo(leafMap);
  for(const[roName,ro]of Object.entries(RO_DATA)){
    const icon=L.divIcon({
      className:'ro-marker-icon',
      html:`<div class="ro-pin" style="background:${ro.color}"><div class="ro-pin-inner">🏢</div></div>`,
      iconSize:[30,30],iconAnchor:[15,30],popupAnchor:[0,-32]
    });
    const m=L.marker([ro.location.lat,ro.location.lng],{icon,zIndexOffset:1000});
    m.bindTooltip(
      `<b>${roName}</b><br><span style="color:${ro.color};font-size:11px">${ro.districts.join(' · ')}</span>`,
      {permanent:false,className:'ap-tip',offset:[0,-32]}
    );
    m.on('click',e=>{L.DomEvent.stopPropagation(e);openROPanel(roName)});
    markersLayer.addLayer(m);
  }
}

function buildLegend(){
  const el=document.getElementById('legItems');el.innerHTML='';
  for(const[name,ro]of Object.entries(RO_DATA)){
    const row=document.createElement('div');row.className='leg-row';
    const short=name.replace(' RO','');
    row.innerHTML=`<div class="leg-swatch" style="background:${ro.color}"></div><span>${short} (${ro.districts.length})</span>`;
    row.addEventListener('click',()=>openROPanel(name));
    el.appendChild(row);
  }
  const pin=document.createElement('div');pin.className='leg-pin-row';
  pin.innerHTML=`<span style="font-size:14px">🏢</span><span>APPCB Regional Office</span>`;
  el.appendChild(pin);
}

function toggleLegend(){
  legOpen=!legOpen;
  document.getElementById('legItems').classList.toggle('hidden',!legOpen);
  const arrow=document.getElementById('legArrow');
  arrow.textContent=legOpen?'▲':'▼';
  arrow.className='leg-toggle-arrow '+(legOpen?'open':'closed');
}

function toggleMapLayer(layer){
  if(layer==='districts'){showDistricts=!showDistricts;document.getElementById('btn-districts').classList.toggle('active',showDistricts);if(geojsonLayer){showDistricts?leafMap.addLayer(geojsonLayer):leafMap.removeLayer(geojsonLayer)}}
  else{showRO=!showRO;document.getElementById('btn-ro').classList.toggle('active',showRO);document.getElementById('btn-ro').classList.toggle('ro-btn',showRO);if(markersLayer){showRO?leafMap.addLayer(markersLayer):leafMap.removeLayer(markersLayer)}}
}

/* ── Side Panel ── */
function openROPanel(roName){
  const ro=RO_DATA[roName];if(!ro)return;
