<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>APPCB – Soil & Buildings Division</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&family=Tiro+Telugu&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<style>
/* ─── PORTAL TOKENS ─── */
:root{
  --cream:#f8f5ef;--parch:#efe9de;--white:#fff;
  --ink:#1c1c1c;--smoke:#6b6b6b;--border:#ddd6c8;
  --forest:#1a5e38;--sage:#3d7a55;
  --red:#c0392b;--nav-h:58px;
  --sh-s:0 2px 12px rgba(0,0,0,.07);
  --sh-m:0 6px 28px rgba(0,0,0,.11);
  --sh-l:0 16px 56px rgba(0,0,0,.18);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--ink);min-height:100vh}

/* NAV */
#nav{position:fixed;top:0;left:0;right:0;height:var(--nav-h);background:var(--forest);
  display:flex;align-items:center;padding:0 20px;gap:12px;z-index:9000;
  box-shadow:0 2px 16px rgba(0,0,0,.28)}
.nav-brand{flex:1;display:flex;flex-direction:column;gap:1px}
.nav-brand-title{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:700;color:#fff}
.nav-brand-sub{font-size:10.5px;color:rgba(255,255,255,.58);letter-spacing:.4px}

/* APP */
#app{padding-top:var(--nav-h);min-height:100vh;transition:padding-top .2s}
body.glocked #app{padding-top:calc(var(--nav-h) + 34px)}
.page{display:none;min-height:calc(100vh - var(--nav-h));flex-direction:column}
.page.active{display:flex}

/* HOME */
#pg-home{align-items:center;justify-content:center;padding:60px 24px 48px;gap:36px;text-align:center}
.home-badge{display:inline-block;background:var(--forest);color:#fff;font-size:10px;
  letter-spacing:2.5px;text-transform:uppercase;padding:5px 16px;border-radius:20px;margin-bottom:18px}
.home-title{font-family:'Cormorant Garamond',serif;font-size:clamp(32px,5.5vw,56px);
  line-height:1.08;color:var(--forest);font-weight:700;margin-bottom:12px;text-align:center}
.home-sub{font-size:15px;color:var(--smoke);max-width:440px;margin:0 auto;line-height:1.6;text-align:center}
.home-cards{display:flex;gap:26px;flex-wrap:wrap;justify-content:center}
.h-card{background:var(--white);border:1px solid var(--border);border-radius:22px;
  padding:34px 28px 26px;width:254px;display:flex;flex-direction:column;
  align-items:center;gap:14px;text-align:center;box-shadow:var(--sh-s)}
.h-card-icon{width:72px;height:72px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:30px}
.hci-soil{background:linear-gradient(135deg,#ede0c8,#c9a96e)}
.hci-bldg{background:linear-gradient(135deg,#c8dde0,#6ea8c9)}
.h-card-name{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:var(--ink)}
.open-btn{margin-top:4px;width:100%;background:var(--forest);color:#fff;border:none;
  padding:12px 0;border-radius:22px;font-family:'DM Sans',sans-serif;font-size:14px;
  font-weight:500;cursor:pointer;transition:background .2s,transform .15s}
.open-btn:hover{background:var(--sage);transform:translateY(-1px)}

/* SEC HEADER */
.sec-hd{background:var(--white);border-bottom:1px solid var(--border);padding:0 18px;
  display:flex;align-items:center;gap:12px;min-height:50px;flex-shrink:0;
  position:sticky;top:var(--nav-h);z-index:200}
.back-btn{background:none;border:none;font-size:20px;cursor:pointer;color:var(--forest);
  padding:4px 8px;border-radius:8px;transition:background .15s;line-height:1}
.back-btn:hover{background:var(--parch)}
.sec-title{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--forest);flex:1}
.breadcrumb{font-size:11px;color:var(--smoke)}
.card-area{flex:1;overflow-y:auto;padding:26px 22px}
.card-grid{display:flex;flex-wrap:wrap;gap:22px;align-content:flex-start;overflow:visible}

/* L1 */
.l1-wrap{display:flex;flex-direction:column;align-items:center;gap:10px;width:128px;position:relative;overflow:visible}
.l1-circle{width:106px;height:106px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-size:36px;box-shadow:var(--sh-s);
  transition:transform .2s,box-shadow .2s;cursor:pointer;position:relative;overflow:visible}
.l1-wrap:hover .l1-circle{transform:scale(1.06);box-shadow:var(--sh-m)}
.l1-label{font-size:12.5px;font-weight:500;text-align:center;color:var(--ink);line-height:1.3;cursor:pointer}
.l1-lock-badge{position:absolute;bottom:2px;right:2px;width:22px;height:22px;border-radius:50%;
  background:rgba(0,0,0,.55);color:#fff;font-size:11px;display:flex;align-items:center;justify-content:center;border:2px solid #fff}
.l1-controls{position:absolute;top:-8px;right:-8px;display:none;gap:4px;flex-direction:column;z-index:20}
.l1-wrap:hover .l1-controls{display:flex}
.l1-ctrl-btn{width:24px;height:24px;border-radius:50%;border:none;cursor:pointer;font-size:11px;
  display:flex;align-items:center;justify-content:center;color:#fff;box-shadow:0 2px 6px rgba(0,0,0,.25);
  transition:transform .15s;z-index:20;position:relative}
.l1-ctrl-btn:hover{transform:scale(1.15)}
.l1-ctrl-btn.del{background:var(--red)}
.l1-ctrl-btn.lk{background:#555}
.l1-ctrl-btn.ren{background:var(--forest)}
.map-l1-circle{background:linear-gradient(135deg,#1a5e38,#3d7a55);color:#fff}
.map-l1-label{font-size:12.5px;font-weight:600;text-align:center;color:var(--forest);line-height:1.3;cursor:pointer}
.add-l1-wrap{display:flex;flex-direction:column;align-items:center;gap:10px;width:128px}
.add-l1-btn{width:106px;height:106px;border-radius:50%;border:2.5px dashed var(--border);
  background:transparent;font-size:32px;color:var(--border);cursor:pointer;transition:all .2s;
  display:flex;align-items:center;justify-content:center}
.add-l1-btn:hover{border-color:var(--forest);color:var(--forest);background:rgba(26,94,56,.04)}
.add-l1-label{font-size:12px;color:#aaa}

/* L2 */
.l2-wrap{display:flex;flex-direction:column;align-items:center;gap:8px;width:108px;position:relative;overflow:visible}
.l2-circle{width:86px;height:86px;border-radius:50%;background:var(--white);
  border:2px solid var(--border);display:flex;align-items:center;justify-content:center;
  font-size:26px;box-shadow:var(--sh-s);transition:transform .2s,border-color .2s,box-shadow .2s;cursor:pointer;position:relative;overflow:visible}
.l2-wrap:hover .l2-circle{border-color:var(--forest);transform:scale(1.07);box-shadow:0 8px 24px rgba(26,94,56,.15)}
.l2-label{font-size:11.5px;font-weight:500;text-align:center;color:var(--ink);line-height:1.3;cursor:pointer}
.l2-lock-badge{position:absolute;bottom:0;right:0;width:20px;height:20px;border-radius:50%;
  background:rgba(0,0,0,.5);color:#fff;font-size:10px;display:flex;align-items:center;justify-content:center;border:2px solid #fff}
.l2-badge{position:absolute;top:-2px;left:-2px;background:var(--forest);color:#fff;font-size:9px;padding:1px 5px;border-radius:8px;z-index:10}
.l2-actions{position:absolute;top:-8px;right:-8px;display:none;gap:3px;z-index:20}
.l2-wrap:hover .l2-actions{display:flex}
.l2-act{width:22px;height:22px;border-radius:50%;border:none;cursor:pointer;font-size:11px;
  display:flex;align-items:center;justify-content:center;color:#fff;
  box-shadow:0 2px 6px rgba(0,0,0,.25);transition:transform .15s;position:relative;z-index:20}
.l2-act:hover{transform:scale(1.15)}
.l2-act.ren{background:var(--forest)}.l2-act.del{background:var(--red)}.l2-act.lk{background:#555}
.add-l2-wrap{display:flex;flex-direction:column;align-items:center;gap:8px;width:108px}
.add-l2-btn{width:86px;height:86px;border-radius:50%;border:2.5px dashed var(--border);
  background:transparent;font-size:26px;color:var(--border);cursor:pointer;transition:all .2s;
  display:flex;align-items:center;justify-content:center}
.add-l2-btn:hover{border-color:var(--forest);color:var(--forest);background:rgba(26,94,56,.04)}
.add-l2-label{font-size:11px;color:#aaa}
/* Locked overlay — pointer-events:none so underlying click handler still fires */
.card-locked-overlay{position:absolute;inset:0;border-radius:50%;background:rgba(0,0,0,.42);
  display:flex;align-items:center;justify-content:center;font-size:22px;
  pointer-events:none;z-index:2}

/* DIALOGS */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);
  z-index:10000;align-items:center;justify-content:center}
.overlay.show{display:flex}
.dlg{background:var(--white);border-radius:22px;padding:28px 26px;max-width:420px;
  width:92%;box-shadow:var(--sh-l);max-height:90vh;overflow-y:auto}
.dlg h3{font-family:'Cormorant Garamond',serif;font-size:21px;color:var(--forest);margin-bottom:16px}
.dlg input,.dlg textarea{width:100%;border:1px solid var(--border);border-radius:10px;
  padding:10px 13px;font-family:'DM Sans',sans-serif;font-size:14px;margin-bottom:12px;
  background:var(--cream);outline:none;transition:border-color .2s}
.dlg input:focus,.dlg textarea:focus{border-color:var(--forest)}
.icon-grid{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:14px}
.icon-opt{width:36px;height:36px;border:1.5px solid var(--border);border-radius:8px;
  cursor:pointer;font-size:17px;display:flex;align-items:center;justify-content:center;transition:all .15s}
.icon-opt:hover,.icon-opt.sel{border-color:var(--forest);background:rgba(26,94,56,.08)}
.dlg-row{display:flex;gap:10px;justify-content:flex-end;margin-top:4px;flex-wrap:wrap}
.btn-p{background:var(--forest);color:#fff;border:none;padding:10px 22px;border-radius:22px;
  cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13.5px;font-weight:500;transition:background .2s}
.btn-p:hover{background:var(--sage)}
.btn-c{background:var(--parch);color:var(--smoke);border:1px solid var(--border);
  padding:10px 22px;border-radius:22px;cursor:pointer;font-family:'DM Sans',sans-serif;font-size:13.5px}
.btn-link{background:none;border:none;color:var(--forest);cursor:pointer;font-size:13px;
  text-decoration:underline;font-family:'DM Sans',sans-serif}

/* FILE MODAL */
#fileModal{z-index:10001}
.fm-inner{background:var(--white);border-radius:22px;max-width:550px;width:95%;
  max-height:88vh;display:flex;flex-direction:column;box-shadow:var(--sh-l)}
.fm-hd{padding:16px 20px 12px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:12px;flex-shrink:0}
.fm-title{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--forest);flex:1}
.fm-close{background:none;border:none;font-size:20px;cursor:pointer;color:var(--smoke)}
.fm-body{padding:16px 20px;overflow-y:auto;flex:1}
.drop-zone{border:2px dashed var(--border);border-radius:14px;padding:24px;text-align:center;
  cursor:pointer;transition:all .2s;margin-bottom:13px}
.drop-zone:hover,.drop-zone.drag{border-color:var(--forest);background:rgba(26,94,56,.04)}
.drop-zone p{color:var(--smoke);font-size:13px;margin-top:6px}
.url-row{display:flex;gap:8px;margin-bottom:13px;flex-wrap:wrap}
.url-row input{flex:1;min-width:110px;border:1px solid var(--border);border-radius:10px;
  padding:9px 12px;font-size:13px;font-family:'DM Sans',sans-serif;background:var(--cream)}
.url-row button{background:var(--forest);color:#fff;border:none;padding:9px 15px;
  border-radius:10px;cursor:pointer;font-size:13px;white-space:nowrap}
.file-list{display:flex;flex-direction:column;gap:7px}
.file-row{display:flex;align-items:center;gap:9px;padding:9px 12px;background:var(--parch);border-radius:10px}
.file-icon{font-size:16px;flex-shrink:0}
.file-name{flex:1;font-size:13px;font-weight:500;cursor:pointer;color:var(--forest);
  text-decoration:underline;text-decoration-color:transparent;transition:.2s}
.file-name:hover{text-decoration-color:var(--forest)}
.file-tag{font-size:9.5px;background:var(--forest);color:#fff;padding:2px 7px;border-radius:8px}
.file-del{background:none;border:none;color:var(--red);cursor:pointer;font-size:13px;padding:2px 6px}
.empty-box{text-align:center;padding:32px 20px;color:var(--smoke)}
.empty-box .ei{font-size:38px;opacity:.33;margin-bottom:9px}

/* PREVIEW */
#previewOv{display:none;position:fixed;inset:0;background:rgba(0,0,0,.87);
  z-index:20000;flex-direction:column;align-items:center;justify-content:center;gap:14px}
#previewOv.show{display:flex}
#previewOv iframe{width:88vw;height:80vh;border:none;border-radius:8px}
#previewOv img{max-width:88vw;max-height:80vh;border-radius:8px}
.prev-close{background:#fff;color:#000;border:none;padding:10px 28px;border-radius:22px;
  cursor:pointer;font-size:14px;font-weight:600}

/* ══════════════════════════════════════
   MAP SCREEN  —  LIGHT & BEAUTIFUL
   Replicates uploaded map's full feature
   set: side panel, tabs, legend, markers
══════════════════════════════════════ */
#mapScreen{display:none;position:fixed;inset:0;z-index:9500;flex-direction:column}
#mapScreen.show{display:flex}

/* Map topbar */
.map-header{background:var(--forest);display:flex;align-items:center;padding:0 16px;
  height:50px;gap:10px;border-bottom:2px solid rgba(255,255,255,.1);flex-shrink:0;flex-wrap:wrap}
.map-header-left{display:flex;align-items:center;gap:10px;flex:1}
.map-logo-box{width:28px;height:28px;background:rgba(255,255,255,.18);border-radius:6px;
  display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.map-header-title h2{font-family:'Cormorant Garamond',serif;font-size:16px;color:#fff;line-height:1}
.map-header-title p{font-size:9px;color:rgba(255,255,255,.55);letter-spacing:.1em;
  text-transform:uppercase;margin-top:1px}
.map-header-controls{display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.layer-btn{font-size:11px;padding:5px 12px;border-radius:20px;
  border:1px solid rgba(255,255,255,.25);background:transparent;
  color:rgba(255,255,255,.7);cursor:pointer;transition:all .2s;
  text-transform:uppercase;letter-spacing:.04em;white-space:nowrap}
.layer-btn.active{background:rgba(255,255,255,.25);color:#fff;font-weight:700;border-color:rgba(255,255,255,.5)}
.layer-btn.active.ro-btn{background:rgba(110,200,160,.25);border-color:rgba(110,200,160,.6);color:#a8f0c8}
.map-back-btn{background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);
  color:#fff;padding:6px 15px;border-radius:20px;cursor:pointer;font-size:12.5px;
  font-family:'DM Sans',sans-serif;transition:background .2s;white-space:nowrap}
.map-back-btn:hover{background:rgba(255,255,255,.22)}
.map-pulse{width:6px;height:6px;background:#7debb0;border-radius:50%;animation:pulse 2s infinite;flex-shrink:0}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.6)}}

/* Map body */
.map-body{flex:1;display:flex;overflow:hidden;position:relative}
#theLeafMap{flex:1}
.leaflet-container{background:linear-gradient(135deg,#e8f5ee 0%,#d4eae0 100%) !important}
.leaflet-tile-pane{display:none !important}
.leaflet-control-zoom a{background:var(--white)!important;color:var(--forest)!important;border-color:var(--border)!important}
.leaflet-control-zoom a:hover{background:var(--parch)!important}
.leaflet-control-attribution{background:rgba(248,245,239,.85)!important;color:var(--smoke)!important;font-size:9px!important}

/* AP tooltip */
.ap-tip{background:var(--white)!important;border:1px solid var(--border)!important;
  color:var(--ink)!important;font-family:'DM Sans',sans-serif!important;
  font-size:12px!important;font-weight:600!important;padding:4px 10px!important;
  border-radius:8px!important;box-shadow:var(--sh-s)!important;white-space:nowrap!important}
.ap-tip::before{display:none!important}

/* ── LEGEND ── */
#mapLegend{position:absolute;bottom:16px;left:14px;z-index:800;
  background:rgba(255,255,255,.97);border:1px solid var(--border);border-radius:14px;
  padding:11px 14px;max-width:200px;box-shadow:var(--sh-m);backdrop-filter:blur(6px)}
.leg-header{cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:8px;
  user-select:none;margin-bottom:0}
.leg-title{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--forest)}
.leg-toggle-arrow{font-size:11px;color:var(--smoke);line-height:1;transition:transform .25s}
.leg-toggle-arrow.open{transform:rotate(0deg)}
.leg-toggle-arrow.closed{transform:rotate(180deg)}
#legItems{margin-top:9px;border-top:1px solid var(--border);padding-top:8px}
#legItems.hidden{display:none}
.leg-row{display:flex;align-items:center;gap:7px;margin-bottom:6px;cursor:pointer;
  font-size:11px;color:var(--smoke);transition:color .15s;border-radius:6px;padding:1px 3px}
.leg-row:hover{color:var(--forest);background:rgba(26,94,56,.04)}
.leg-swatch{width:13px;height:13px;border-radius:3px;flex-shrink:0;
  border:1px solid rgba(0,0,0,.08);box-shadow:0 1px 3px rgba(0,0,0,.1)}
.leg-pin-row{display:flex;align-items:center;gap:7px;padding-top:7px;margin-top:3px;
  border-top:1px solid var(--border);font-size:11px;color:var(--smoke)}

/* ── RO PIN marker ── */
.ro-marker-icon{background:transparent;border:none}
.ro-pin{width:30px;height:30px;border-radius:50% 50% 50% 0;transform:rotate(-45deg);
  display:flex;align-items:center;justify-content:center;
  border:2px solid rgba(255,255,255,.85);
  box-shadow:0 3px 12px rgba(0,0,0,.22),0 1px 4px rgba(0,0,0,.15);
  cursor:pointer;transition:transform .15s}
.ro-pin:hover{transform:rotate(-45deg) scale(1.15)}
.ro-pin-inner{transform:rotate(45deg);font-size:13px;line-height:1}

/* ── SIDE PANEL ── */
.map-panel{width:0;overflow:hidden;background:var(--white);
  border-left:1px solid var(--border);
  transition:width .38s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;flex-shrink:0;
  box-shadow:-3px 0 20px rgba(0,0,0,.08)}
.map-panel.open{width:380px}
.panel-inner{width:380px;height:100%;display:flex;flex-direction:column;overflow:hidden}

.panel-hd{padding:15px 16px 11px;border-bottom:1px solid var(--border);flex-shrink:0;position:relative}
.panel-type-badge{font-size:9px;text-transform:uppercase;letter-spacing:.14em;
  padding:3px 10px;border-radius:20px;margin-bottom:8px;display:inline-block;font-weight:700}
.badge-ro{background:rgba(26,94,56,.1);border:1px solid rgba(26,94,56,.25);color:var(--forest)}
.badge-dist{background:rgba(184,150,46,.1);border:1px solid rgba(184,150,46,.3);color:#8a6e10}
.panel-name{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--ink);line-height:1.1}
.panel-sub{font-size:12px;color:var(--smoke);margin-top:3px}
.panel-telugu{font-family:'Tiro Telugu',serif;font-size:13px;color:var(--sage);margin-top:3px}
.panel-meta{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px}
.meta-pill{font-size:10px;padding:2px 8px;border-radius:12px;
  background:rgba(26,94,56,.07);border:1px solid rgba(26,94,56,.14);color:var(--forest)}
.panel-close-btn{position:absolute;top:12px;right:12px;background:var(--parch);
  border:1px solid var(--border);color:var(--smoke);width:28px;height:28px;border-radius:50%;
  cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;transition:all .2s}
.panel-close-btn:hover{background:var(--border)}

/* Panel tabs */
.panel-tabs{display:flex;border-bottom:1px solid var(--border);background:var(--parch);flex-shrink:0}
.panel-tab{flex:1;padding:9px 6px;font-size:10px;text-align:center;text-transform:uppercase;
  letter-spacing:.08em;font-weight:600;color:var(--smoke);cursor:pointer;
  border-bottom:2.5px solid transparent;transition:all .2s}
.panel-tab.active{color:var(--forest);border-bottom-color:var(--forest);background:var(--white)}

/* Panel body */
.panel-body{flex:1;overflow-y:auto;padding:14px 16px;
  scrollbar-width:thin;scrollbar-color:rgba(26,94,56,.15) transparent}
.panel-body::-webkit-scrollbar{width:3px}
.panel-body::-webkit-scrollbar-thumb{background:rgba(26,94,56,.15);border-radius:3px}

/* Panel content pieces */
.addr-card{background:rgba(26,94,56,.05);border:1px solid rgba(26,94,56,.12);
  border-radius:10px;padding:10px 13px;margin-bottom:12px;font-size:13px;line-height:1.6;color:var(--ink)}
.addr-label{font-size:9.5px;text-transform:uppercase;letter-spacing:.1em;
  color:var(--sage);margin-bottom:4px;font-weight:700}
.stats-row{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:14px}
.stat-card{background:var(--parch);border:1px solid var(--border);border-radius:9px;padding:8px 10px}
.stat-label{font-size:9.5px;color:var(--smoke);text-transform:uppercase;letter-spacing:.08em}
.stat-value{font-size:17px;font-weight:700;color:var(--forest);
  font-family:'Cormorant Garamond',serif;margin-top:2px}
.section-hd{font-size:9.5px;text-transform:uppercase;letter-spacing:.12em;color:var(--sage);
  font-weight:700;margin:14px 0 9px;display:flex;align-items:center;gap:8px}
.section-hd::after{content:'';flex:1;height:1px;background:rgba(26,94,56,.12)}
.dist-chip-grid{display:flex;flex-wrap:wrap;gap:5px;margin-bottom:12px}
.dist-chip{font-size:11px;padding:4px 10px;border-radius:6px;cursor:pointer;
  transition:all .2s;font-weight:600;border:1px solid rgba(255,255,255,.3)}
.dist-chip:hover{filter:brightness(.88);transform:translateY(-1px)}

/* Timeline */
.timeline{position:relative;padding-left:20px}
.timeline::before{content:'';position:absolute;left:4px;top:8px;bottom:8px;width:2px;
  background:linear-gradient(to bottom,var(--forest),rgba(26,94,56,.1));border-radius:2px}
.tl-item{position:relative;margin-bottom:13px;animation:tlFade .3s ease both}
.tl-item:nth-child(1){animation-delay:.03s}.tl-item:nth-child(2){animation-delay:.07s}
.tl-item:nth-child(3){animation-delay:.11s}.tl-item:nth-child(4){animation-delay:.15s}
@keyframes tlFade{from{opacity:0;transform:translateX(6px)}to{opacity:1;transform:none}}
.tl-dot{position:absolute;left:-16px;top:5px;width:8px;height:8px;border-radius:50%;border:2px solid var(--cream)}
.tl-dot.d{background:var(--forest);box-shadow:0 0 5px rgba(26,94,56,.3)}
.tl-dot.i{background:var(--sage);box-shadow:0 0 5px rgba(61,122,85,.25)}
.tl-dot.h{background:#8b6914;box-shadow:0 0 5px rgba(139,105,20,.25)}
.tl-year{font-size:11px;font-weight:700;letter-spacing:.05em;margin-bottom:1px}
.tl-year.d{color:var(--forest)}.tl-year.i{color:var(--sage)}.tl-year.h{color:#8b6914}
.tl-text{font-size:13px;line-height:1.55;color:var(--ink)}

/* Editable areas */
.editable-area{width:100%;background:var(--parch);border:1px solid var(--border);
  border-radius:9px;color:var(--ink);font-family:'DM Sans',sans-serif;font-size:13px;
  line-height:1.6;padding:10px 12px;resize:vertical;min-height:140px;
  outline:none;transition:border-color .2s}
.editable-area:focus{border-color:var(--forest);background:var(--white)}
.editable-area::placeholder{color:rgba(107,107,107,.45)}
.save-row{display:flex;justify-content:flex-end;align-items:center;margin-top:8px;gap:10px}
.save-btn{font-size:12px;padding:6px 16px;border-radius:8px;background:rgba(26,94,56,.1);
  border:1px solid rgba(26,94,56,.28);color:var(--forest);cursor:pointer;font-weight:700;transition:all .2s}
.save-btn:hover{background:rgba(26,94,56,.18)}
.saved-notice{font-size:11px;color:var(--sage);opacity:0;transition:opacity .3s}
.saved-notice.show{opacity:1}

@media(max-width:640px){
  .home-cards{flex-direction:column}.h-card{width:100%;max-width:290px}
  .map-panel.open{width:100vw;position:absolute;right:0;top:50px;bottom:0;z-index:900}
  .panel-inner{width:100vw}
  #mapLegend{display:none}
}

/* ══════════════════════════════════════
   RENAME DIALOG
══════════════════════════════════════ */
.rename-preview{
  display:flex;align-items:center;gap:10px;
  background:var(--parch);border:1px solid var(--border);
  border-radius:10px;padding:10px 13px;margin-bottom:14px;
}
.rename-preview-icon{font-size:26px}
.rename-preview-name{font-size:13px;color:var(--smoke)}

/* L1 rename button */
.l1-ctrl-btn.ren{background:var(--forest)}

/* ══════════════════════════════════════
   CARD LOCK METHOD PICKER
   (same 3-method system as global lock,
    but scoped to individual cards)
══════════════════════════════════════ */
.cl-method-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin:12px 0}
.cl-method-card{border:2px solid var(--border);border-radius:12px;padding:12px 8px;
  text-align:center;cursor:pointer;transition:all .2s;background:var(--cream)}
.cl-method-card:hover{border-color:var(--forest);background:rgba(26,94,56,.05)}
.cl-method-card.sel{border-color:var(--forest);background:rgba(26,94,56,.09)}
.cl-method-icon{font-size:22px;margin-bottom:4px}
.cl-method-name{font-size:11px;font-weight:600;color:var(--ink)}
/* card otp-input (reuse global style) */
/* card face box — smaller than global */
.cl-face-box{position:relative;width:160px;height:160px;margin:0 auto 10px;
  border-radius:50%;overflow:hidden;background:#000;border:3px solid var(--forest)}
.cl-face-box video{width:100%;height:100%;object-fit:cover}
.cl-face-overlay{position:absolute;inset:0;border-radius:50%;border:3px solid transparent;transition:border-color .3s}
.cl-face-overlay.scanning{border-color:#22c55e;animation:facePulse 1s ease-in-out infinite}

/* ══════════════════════════════════════
   GLOBAL LOCK SYSTEM
══════════════════════════════════════ */
/* Lock button in nav */
#gLockBtn{
  background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.3);
  color:#fff;padding:6px 14px;border-radius:20px;cursor:pointer;
  font-family:'DM Sans',sans-serif;font-size:12.5px;font-weight:600;
  display:flex;align-items:center;gap:6px;transition:all .2s;white-space:nowrap;
  flex-shrink:0;
}
#gLockBtn:hover{background:rgba(255,255,255,.25)}
#gLockBtn.locked{background:rgba(220,60,60,.35);border-color:rgba(255,100,100,.5)}

/* Lock banner */
#gLockBanner{
  display:none;position:fixed;top:var(--nav-h);left:0;right:0;z-index:8500;
  background:linear-gradient(90deg,#b91c1c,#991b1b);
  padding:7px 18px;font-size:12.5px;color:#fff;
  display:none;align-items:center;justify-content:center;gap:10px;
  font-family:'DM Sans',sans-serif;font-weight:500;
}
#gLockBanner.show{display:flex}
#gLockBanner strong{font-weight:700}
.gband-unlock{background:rgba(255,255,255,.2);border:1px solid rgba(255,255,255,.4);
  color:#fff;padding:3px 12px;border-radius:12px;cursor:pointer;font-size:12px;
  font-family:'DM Sans',sans-serif;margin-left:4px}
.gband-unlock:hover{background:rgba(255,255,255,.32)}

/* when locked, hide only add/upload/delete actions — lock & rename btns stay visible */
body.glocked .add-l1-wrap,
body.glocked .add-l2-wrap,
body.glocked .drop-zone,
body.glocked .url-row,
body.glocked .file-del{display:none!important}
/* hide only the ren and del buttons when globally locked, but keep lk button */
body.glocked .l1-ctrl-btn.ren,
body.glocked .l1-ctrl-btn.del,
body.glocked .l2-act.ren,
body.glocked .l2-act.del{display:none!important}

/* Method picker dialog */
.lk-method-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:14px 0}
.lk-method-card{border:2px solid var(--border);border-radius:14px;padding:16px 10px;
  text-align:center;cursor:pointer;transition:all .2s;background:var(--cream)}
.lk-method-card:hover{border-color:var(--forest);background:rgba(26,94,56,.05)}
.lk-method-card.sel{border-color:var(--forest);background:rgba(26,94,56,.08)}
.lk-method-icon{font-size:26px;margin-bottom:6px}
.lk-method-name{font-size:12px;font-weight:600;color:var(--ink)}
.lk-method-desc{font-size:10.5px;color:var(--smoke);margin-top:3px;line-height:1.4}

/* OTP input */
.otp-input{letter-spacing:.35em;font-size:22px;font-family:'DM Mono',monospace,sans-serif;
  text-align:center;font-weight:700;color:var(--forest)}

/* Face scan area */
.face-box{position:relative;width:200px;height:200px;margin:0 auto 14px;border-radius:50%;
  overflow:hidden;background:#000;border:3px solid var(--forest)}
.face-box video{width:100%;height:100%;object-fit:cover}
.face-overlay{position:absolute;inset:0;border-radius:50%;
  border:3px solid transparent;transition:border-color .3s}
.face-overlay.scanning{border-color:#22c55e;
  animation:facePulse 1s ease-in-out infinite}
@keyframes facePulse{0%,100%{box-shadow:0 0 0 0 rgba(34,197,94,.4)}
  50%{box-shadow:0 0 0 12px rgba(34,197,94,0)}}
.face-status{font-size:12.5px;text-align:center;color:var(--smoke);min-height:18px}
.face-bar-wrap{background:var(--parch);border-radius:8px;height:6px;margin:8px 0;overflow:hidden}
.face-bar{height:100%;border-radius:8px;background:var(--forest);
  width:0%;transition:width .3s}
</style>
</head>
<body>

<nav id="nav">
