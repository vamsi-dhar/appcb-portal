function closePanel(){document.getElementById('sidePanel').classList.remove('open');_panelRO=null}

function switchTab(tab){
  currentTab=tab;
  document.querySelectorAll('.panel-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  if(_panelRO)renderROTab(tab);
}

function renderROTab(tab){
  const ro=RO_DATA[_panelRO];if(!ro)return;
  const body=document.getElementById('panelBody');
  if(tab==='overview'){
    let html=`<div class="addr-card"><div class="addr-label">📍 Office Address</div>${ro.address}</div>`;
    if(ro.phone)html+=`<div class="addr-card" style="margin-top:-6px"><div class="addr-label">📞 Phone</div>${ro.phone}</div>`;
    html+=`<div class="stats-row">`;
    ro.stats.forEach(s=>html+=`<div class="stat-card"><div class="stat-label">${s.label}</div><div class="stat-value">${s.value}</div></div>`);
    html+=`</div>`;
    html+=`<div class="section-hd">Districts Under This RO</div><div class="dist-chip-grid">`;
    ro.districts.forEach(d=>html+=`<div class="dist-chip" style="background:${ro.color}22;color:${ro.color};border-color:${ro.color}44" onclick="openDistPanel('${d}')">${d}</div>`);
    html+=`</div>`;
    html+=`<div class="section-hd">Chronology</div><div class="timeline">`;
    const saved=lsRaw('appcb7_ov_'+ro.id,'');
    let items;try{items=saved?JSON.parse(saved):ro.overview}catch{items=ro.overview}
    items.forEach(item=>html+=`<div class="tl-item"><div class="tl-dot ${item.type||'i'}"></div><div class="tl-year ${item.type||'i'}">${item.year}</div><div class="tl-text">${item.text}</div></div>`);
