<script>
/* ══════ STORAGE ══════ */
const LS={
  get(k,d=null){try{const v=localStorage.getItem('appcb7_'+k);return v!==null?JSON.parse(v):d}catch{return d}},
  set(k,v){try{localStorage.setItem('appcb7_'+k,JSON.stringify(v))}catch{}},
  del(k){try{localStorage.removeItem('appcb7_'+k)}catch{}}
};
function lsRaw(k,d=''){try{return localStorage.getItem(k)||d}catch{return d}}
function lsRawSet(k,v){try{localStorage.setItem(k,v)}catch{}}

/* ══════ NAV ══════ */
let navStack=[];
function pushNav(s){navStack.push(s)}
function navBack(){navStack.pop();if(!navStack.length){goHome();return}const p=navStack[navStack.length-1];reapplyNav(p);}
function reapplyNav(s){showPage(s.page);if(s.sec){document.getElementById(s.sec+'-title').textContent=s.title;document.getElementById(s.sec+'-bread').textContent=s.bread;if(s.l1){currentL1=s.l1;renderL2(s.sec,s.l1.id,document.getElementById(s.sec+'-grid'))}else{currentL1=null;renderL1(s.sec)}}saveNavState();}
function goHome(){navStack=[];currentL1=null;currentSec='';showPage('pg-home');saveNavState();}
function showPage(id){document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));document.getElementById(id).classList.add('active');}

/* ── Persist nav state in sessionStorage so refresh stays on same page ── */
function saveNavState(){
  try{
    const state={sec:currentSec,l1:currentL1?{id:currentL1.id,name:currentL1.name,icon:currentL1.icon,bg:currentL1.bg||''}:null};
    sessionStorage.setItem('appcb_nav',JSON.stringify(state));
  }catch(e){}
}
function restoreNavState(){
  try{
    const raw=sessionStorage.getItem('appcb_nav');
    if(!raw)return;
    const s=JSON.parse(raw);
    if(!s||!s.sec)return;
    currentSec=s.sec;
    if(s.l1){
      currentL1=s.l1;
      const title=s.l1.icon+' '+s.l1.name;
      const label=s.sec==='soil'?'Soil':'Buildings';
      const bread='Home → '+label+' → '+s.l1.name;
      navStack=[
        {page:'pg-'+s.sec,sec:s.sec,l1:null,title:s.sec==='soil'?'🪨 Soil Division':'🏛️ Buildings Division',bread:'Home → '+label},
        {page:'pg-'+s.sec,sec:s.sec,l1:s.l1,title,bread}
      ];
      showPage('pg-'+s.sec);
      document.getElementById(s.sec+'-title').textContent=title;
      document.getElementById(s.sec+'-bread').textContent=bread;
      renderL2(s.sec,s.l1.id,document.getElementById(s.sec+'-grid'));
    } else {
      const title=s.sec==='soil'?'🪨 Soil Division':'🏛️ Buildings Division';
      const label=s.sec==='soil'?'Soil':'Buildings';
      const bread='Home → '+label;
      navStack=[{page:'pg-'+s.sec,sec:s.sec,l1:null,title,bread}];
      showPage('pg-'+s.sec);
      document.getElementById(s.sec+'-title').textContent=title;
      document.getElementById(s.sec+'-bread').textContent=bread;
      renderL1(s.sec);
    }
  }catch(e){}
}
window.addEventListener('load', restoreNavState);

// Keyboard support
document.addEventListener('keydown',e=>{
  if(e.key==='Escape'){
    // Close map first if open
    if(document.getElementById('mapScreen').classList.contains('show')){closeMap();return;}
    // Close preview
    if(document.getElementById('previewOv').classList.contains('show')){closePreview();return;}
    // Close file modal
    if(document.getElementById('fileModal').classList.contains('show')){closeFileModal();return;}
    // Close dialogs (global lock dialogs first, then card lock, then rename/add)
    for(const id of ['gFaceUnlDlg','gFaceSetDlg','gOtpUnlDlg','gOtpSetDlg','gPwdUnlDlg','gPwdSetDlg','gMethodDlg','clFaceUnlDlg','clFaceSetDlg','clOtpUnlDlg','clOtpSetDlg','cardLockDlg','renameDlg','addL2Dlg','addL1Dlg']){
      if(document.getElementById(id).classList.contains('show')){
        if(id==='gFaceSetDlg') gFaceCancel('set');
        else if(id==='gFaceUnlDlg') gFaceCancel('unl');
        else if(id==='clFaceSetDlg') clFaceCancel('set');
        else if(id==='clFaceUnlDlg') clFaceCancel('unl');
        else closeDlg(id);
        return;
      }
    }
  }
  if(e.key==='Enter'){
    if(document.getElementById('gPwdSetDlg').classList.contains('show')){gPwdSetConfirm();return;}
    if(document.getElementById('gPwdUnlDlg').classList.contains('show')){gPwdUnlConfirm();return;}
    if(document.getElementById('gOtpUnlDlg').classList.contains('show')){gOtpUnlConfirm();return;}
    if(document.getElementById('renameDlg').classList.contains('show')){confirmRename();return;}
    if(document.getElementById('addL1Dlg').classList.contains('show')){confirmAddL1();return;}
    if(document.getElementById('addL2Dlg').classList.contains('show')){confirmAddL2();return;}
    if(document.getElementById('cardLockDlg').classList.contains('show')){
      const lk=document.getElementById('clPw2');
      const ul=document.getElementById('clUnPw');
      if(lk)doCardLock();else if(ul)doCardUnlock();
      return;
    }
    if(document.getElementById('clOtpUnlDlg').classList.contains('show')){clOtpUnlConfirm();return;}
  }
});

/* ══════ APP STATE ══════ */
let currentSec='',currentL1=null,addL1Sec='',addL2Ctx=null,fmCtx=null,selIcon='📄';
let cardLockKey='',cardLockCb=null;
let renameCtx=null; // {type:'l1'|'l2', sec, l1id, itemId, cb}
const ICONS=['📄','📁','📊','📋','📝','🔍','⚠️','✅','🏗️','🌿','♻️','💧','🔬','📌','📎','🖼️','🌐','📜','🗂️','📦','⚙️','🏢','💡','🔑','📐','🧾','🛡️','🧪','📡','📉'];
const DEFAULT_SOIL=[
  {id:'plastic',name:'Plastic Waste',icon:'♻️',bg:'#e8f3ec'},
  {id:'ewaste',name:'E-Waste',icon:'💻',bg:'#e8ecf3'},
  {id:'battery',name:'Battery Waste',icon:'🔋',bg:'#f3f3e8'},
  {id:'cnd',name:'C&D Waste',icon:'🧱',bg:'#f3ece8'},
  {id:'flyash',name:'Fly Ash',icon:'🌫️',bg:'#efe8f3'},
  {id:'circular',name:'Circular Economy',icon:'🔄',bg:'#e8f0f3'},
  {id:'training',name:'Training & Workshops',icon:'🎓',bg:'#f3e8ed'},
];
const DEFAULT_BLDG=[
  {id:'landrecords',name:'Land Records',icon:'📋',bg:'#e8eff3'},
  {id:'constructions',name:'Constructions',icon:'🏗️',bg:'#f3ece8'},
  {id:'leases',name:'Leases & Rentals',icon:'📝',bg:'#e8f3ec'},
  {id:'repairs',name:'Repairs & Maintenance',icon:'🔧',bg:'#f3f0e8'},
  {id:'legal',name:'Legal & Disputes',icon:'⚖️',bg:'#ece8f3'},
  {id:'budget',name:'Budget & Finance',icon:'💰',bg:'#e8f3ef'},
];
const getL1=s=>LS.get('l1_'+s,JSON.parse(JSON.stringify(s==='soil'?DEFAULT_SOIL:DEFAULT_BLDG)));
const saveL1=(s,a)=>LS.set('l1_'+s,a);
const getL2=(s,i)=>LS.get('l2_'+s+'_'+i,[]);
const saveL2=(s,i,a)=>LS.set('l2_'+s+'_'+i,a);
const getFiles=(s,l1,l2)=>LS.get('files_'+s+'_'+l1+'_'+l2,[]);
const saveFiles=(s,l1,l2,a)=>LS.set('files_'+s+'_'+l1+'_'+l2,a);


function openSection(sec){currentSec=sec;currentL1=null;navStack=[];const title=sec==='soil'?'🪨 Soil Division':'🏛️ Buildings Division';const bread='Home → '+(sec==='soil'?'Soil':'Buildings');pushNav({page:'pg-'+sec,sec,l1:null,title,bread});showPage('pg-'+sec);document.getElementById(sec+'-title').textContent=title;document.getElementById(sec+'-bread').textContent=bread;renderL1(sec);saveNavState();}

function renderL1(sec){currentL1=null;const grid=document.getElementById(sec+'-grid');grid.innerHTML='';if(sec==='bldg'){const w=document.createElement('div');w.className='l1-wrap';w.innerHTML=`<div class="l1-circle map-l1-circle" style="cursor:pointer">🗺️</div><div class="map-l1-label">Lands &amp; Buildings<br><em>RO Status Map</em></div>`;w.querySelector('.l1-circle').addEventListener('click',openMap);w.querySelector('.map-l1-label').addEventListener('click',openMap);grid.appendChild(w)}getL1(sec).forEach(s=>{const key='l1_'+sec+'_'+s.id;const locked=isCardLocked(key);const cb=()=>renderL1(sec);const w=document.createElement('div');w.className='l1-wrap';w.innerHTML=`<div class="l1-circle" style="background:${s.bg||'#e8f3ec'}">${s.icon}${locked?'<div class="card-locked-overlay">🔒</div>':''}</div><div class="l1-label">${s.name}</div><div class="l1-controls"><button class="l1-ctrl-btn ren" title="Rename">✏️</button><button class="l1-ctrl-btn del" title="Delete">🗑</button><button class="l1-ctrl-btn lk">${locked?'🔓':'🔒'}</button></div>`;w.querySelector('.l1-circle').addEventListener('click',()=>locked?openCardUnlock(key,cb):openL1(sec,s));w.querySelector('.l1-label').addEventListener('click',()=>locked?openCardUnlock(key,cb):openL1(sec,s));w.querySelector('.l1-ctrl-btn.ren').addEventListener('click',e=>{e.stopPropagation();if(!editGuard())return;if(locked){alert('Unlock card first.');return}openRenameDialog({type:'l1',sec,itemId:s.id,icon:s.icon,name:s.name,cb})});w.querySelector('.l1-ctrl-btn.del').addEventListener('click',e=>{e.stopPropagation();deleteL1(sec,s.id)});w.querySelector('.l1-ctrl-btn.lk').addEventListener('click',e=>{e.stopPropagation();locked?openCardUnlock(key,cb):openCardLock(key,cb)});grid.appendChild(w)});const aw=document.createElement('div');aw.className='add-l1-wrap';aw.innerHTML=`<button class="add-l1-btn">＋</button><div class="add-l1-label">Add Category</div>`;aw.querySelector('.add-l1-btn').addEventListener('click',()=>openAddL1(sec));grid.appendChild(aw)}
function openL1(sec,s){currentL1=s;const label=sec==='soil'?'Soil':'Buildings';const title=s.icon+' '+s.name;const bread='Home → '+label+' → '+s.name;document.getElementById(sec+'-title').textContent=title;document.getElementById(sec+'-bread').textContent=bread;pushNav({page:'pg-'+sec,sec,l1:s,title,bread});renderL2(sec,s.id,document.getElementById(sec+'-grid'));saveNavState();}
function renderL2(sec,l1id,grid){grid.innerHTML='';getL2(sec,l1id).forEach(c=>{const key='l2_'+sec+'_'+l1id+'_'+c.id;const locked=isCardLocked(key);const fc=(getFiles(sec,l1id,c.id)||[]).length;const w=document.createElement('div');w.className='l2-wrap';w.innerHTML=`<div class="l2-circle">${c.icon}${locked?'<div class="card-locked-overlay" style="font-size:18px">🔒</div>':''}</div>${fc?`<div class="l2-badge">${fc}</div>`:''}<div class="l2-label">${c.name}</div><div class="l2-actions"><button class="l2-act ren">✏️</button><button class="l2-act del">🗑</button><button class="l2-act lk">${locked?'🔓':'🔒'}</button></div>`;const cb=()=>renderL2(sec,l1id,grid);w.querySelector('.l2-circle').addEventListener('click',()=>locked?openCardUnlock(key,cb):openFileModal(sec,l1id,c));w.querySelector('.l2-label').addEventListener('click',()=>locked?openCardUnlock(key,cb):openFileModal(sec,l1id,c));w.querySelector('.l2-act.ren').addEventListener('click',e=>{e.stopPropagation();if(!editGuard())return;if(locked){alert('Unlock card first.');return}openRenameDialog({type:'l2',sec,l1id,itemId:c.id,icon:c.icon,name:c.name,cb})});w.querySelector('.l2-act.del').addEventListener('click',e=>{e.stopPropagation();if(!editGuard())return;if(locked){alert('Unlock card first.');return}if(confirm('Delete "'+c.name+'" and all files?')){saveL2(sec,l1id,getL2(sec,l1id).filter(x=>x.id!==c.id));LS.del('files_'+sec+'_'+l1id+'_'+c.id);cb()}});w.querySelector('.l2-act.lk').addEventListener('click',e=>{e.stopPropagation();locked?openCardUnlock(key,cb):openCardLock(key,cb)});grid.appendChild(w)});const aw=document.createElement('div');aw.className='add-l2-wrap';aw.innerHTML=`<button class="add-l2-btn">＋</button><div class="add-l2-label">Add Card</div>`;aw.querySelector('.add-l2-btn').addEventListener('click',()=>openAddL2(sec,l1id,grid));grid.appendChild(aw)}
function openAddL1(sec){if(!editGuard())return;addL1Sec=sec;selIcon='📄';document.getElementById('l1NameIn').value='';buildIconGrid('l1IconGrid');document.getElementById('addL1Dlg').classList.add('show')}
function confirmAddL1(){const n=document.getElementById('l1NameIn').value.trim();if(!n){alert('Enter a name.');return}const a=getL1(addL1Sec);const bgs=['#e8f3ec','#e8ecf3','#f3f3e8','#f3ece8','#efe8f3','#e8f0f3','#f3e8ed'];a.push({id:'l1_'+Date.now(),name:n,icon:selIcon||'📄',bg:bgs[a.length%bgs.length]});saveL1(addL1Sec,a);closeDlg('addL1Dlg');renderL1(addL1Sec)}
function deleteL1(sec,id){if(!editGuard())return;const a=getL1(sec);const item=a.find(x=>x.id===id);if(!item)return;if(!confirm('Delete "'+item.name+'" and all cards?'))return;saveL1(sec,a.filter(x=>x.id!==id));renderL1(sec)}
function openAddL2(sec,l1id,grid){if(!editGuard())return;addL2Ctx={sec,l1id,grid};selIcon='📄';document.getElementById('l2NameIn').value='';buildIconGrid('l2IconGrid');document.getElementById('addL2Dlg').classList.add('show')}
function confirmAddL2(){const n=document.getElementById('l2NameIn').value.trim();if(!n){alert('Enter a name.');return}const{sec,l1id,grid}=addL2Ctx;const a=getL2(sec,l1id);a.push({id:'c_'+Date.now(),name:n,icon:selIcon||'📄'});saveL2(sec,l1id,a);closeDlg('addL2Dlg');renderL2(sec,l1id,grid)}
function buildIconGrid(cid){const c=document.getElementById(cid);c.innerHTML='';ICONS.forEach(ic=>{const el=document.createElement('div');el.className='icon-opt'+(ic===selIcon?' sel':'');el.textContent=ic;el.addEventListener('click',()=>{c.querySelectorAll('.icon-opt').forEach(x=>x.classList.remove('sel'));el.classList.add('sel');selIcon=ic});c.appendChild(el)})}
async function sha256(s){const b=await crypto.subtle.digest('SHA-256',new TextEncoder().encode(s));return Array.from(new Uint8Array(b)).map(x=>x.toString(16).padStart(2,'0')).join('')}
/* ══════════════════════════════════════════════════
   RENAME DIALOG
══════════════════════════════════════════════════ */
function openRenameDialog(ctx){
  renameCtx=ctx;
  document.getElementById('renIcon').textContent=ctx.icon||'📄';
  document.getElementById('renOldName').textContent='Current: '+ctx.name;
  const inp=document.getElementById('renNameIn');
  inp.value=ctx.name;
  document.getElementById('renameDlg').classList.add('show');
  setTimeout(()=>{inp.select();},80);
}
function confirmRename(){
  const n=document.getElementById('renNameIn').value.trim();
  if(!n){alert('Enter a name.');return}
  if(!renameCtx)return;
  const {type,sec,l1id,itemId,cb}=renameCtx;
  if(type==='l1'){
    const a=getL1(sec);
    const i=a.findIndex(x=>x.id===itemId);
    if(i>=0){a[i].name=n;saveL1(sec,a);}
  } else {
    const a=getL2(sec,l1id);
    const i=a.findIndex(x=>x.id===itemId);
    if(i>=0){a[i].name=n;saveL2(sec,l1id,a);}
  }
  closeDlg('renameDlg');
  renameCtx=null;
  cb();
}

/* ══════════════════════════════════════════════════
   PER-CARD LOCK ENGINE — 3 Methods
   Password · Email OTP · Face ID
   (same methods as global lock but per-card scoped)
══════════════════════════════════════════════════ */
// cardLockData: {method:'pwd'|'otp'|'face', hash?, otpCfg?, faceData?}
const getCardLockData=k=>LS.get('cl_'+k,null);
const setCardLockData=(k,v)=>v?LS.set('cl_'+k,v):LS.del('cl_'+k);
// Override old helpers to be compatible
function getCardLock(k){return getCardLockData(k)}
function setCardLock(k,v){setCardLockData(k,v)}
function isCardLocked(k){return getCardLockData(k)!==null}

let _clSelMethod=null, _clOtp='', _clStream=null;

/* ── Open Lock Dialog (set lock) ── */
function openCardLock(key,cb){
  cardLockKey=key; cardLockCb=cb;
  _clSelMethod=null;
  document.getElementById('clTitle').textContent='🔒 Lock This Card';
  document.getElementById('clBody').innerHTML=`
    <p style="font-size:13px;color:var(--smoke);margin-bottom:4px">Choose how to lock this card. Viewing is always possible — only editing requires unlock.</p>
    <div class="cl-method-grid">
      <div class="cl-method-card" id="clmc-pwd" onclick="clSelectMethod('pwd')">
        <div class="cl-method-icon">🔑</div>
        <div class="cl-method-name">Password</div>
      </div>
      <div class="cl-method-card" id="clmc-otp" onclick="clSelectMethod('otp')">
        <div class="cl-method-icon">📧</div>
        <div class="cl-method-name">Email OTP</div>
      </div>
      <div class="cl-method-card" id="clmc-face" onclick="clSelectMethod('face')">
        <div class="cl-method-icon">👁️</div>
        <div class="cl-method-name">Face ID</div>
      </div>
    </div>
    <div class="dlg-row">
      <button class="btn-c" onclick="closeDlg('cardLockDlg')">Cancel</button>
      <button class="btn-p" onclick="clProceedLock()">Next →</button>
    </div>`;
  document.getElementById('cardLockDlg').classList.add('show');
}

function clSelectMethod(m){
  _clSelMethod=m;
  document.querySelectorAll('.cl-method-card').forEach(c=>c.classList.remove('sel'));
