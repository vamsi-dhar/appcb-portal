}

/* ── OTP Lock ── */
async function clOtpSetConfirm(){
  const pub=document.getElementById('clEjsPub').value.trim();
  const svc=document.getElementById('clEjsSvc').value.trim();
  const tpl=document.getElementById('clEjsTpl').value.trim();
  const email=document.getElementById('clEjsEmail').value.trim();
  if(!pub||!svc||!tpl||!email){alert('Fill all fields.');return}
  setCardLockData(cardLockKey,{method:'otp',otpCfg:{pub,svc,tpl,email}});
  ['clEjsPub','clEjsSvc','clEjsTpl','clEjsEmail'].forEach(id=>document.getElementById(id).value='');
  closeDlg('clOtpSetDlg');
  if(cardLockCb)cardLockCb();
}

async function clSendOtp(){
  const data=getCardLockData(cardLockKey);
  if(!data||!data.otpCfg)return;
  const cfg=data.otpCfg;
  _clOtp=String(Math.floor(100000+Math.random()*900000));
  document.getElementById('clOtpMsg').textContent='Sending OTP to '+cfg.email+'…';
  document.getElementById('clOtpIn').value='';
  try{
    await new Promise((res,rej)=>{
      if(window.emailjs){res();return}
      const s=document.createElement('script');s.onload=res;s.onerror=rej;
      s.src='https://cdn.jsdelivr.net/npm/@emailjs/browser@3/dist/email.min.js';
      document.head.appendChild(s);
    });
    await emailjs.send(cfg.svc,cfg.tpl,{otp:_clOtp,to_email:cfg.email},cfg.pub);
    document.getElementById('clOtpMsg').textContent='OTP sent to '+cfg.email+'.';
  }catch(e){
    document.getElementById('clOtpMsg').textContent='Send failed. Check EmailJS config.';
  }
}

function clOtpUnlConfirm(){
  const entered=document.getElementById('clOtpIn').value.trim();
  if(entered===_clOtp&&_clOtp){
    _clOtp='';
    document.getElementById('clOtpIn').value='';
    closeDlg('clOtpUnlDlg');
    setCardLockData(cardLockKey,null);
    if(cardLockCb)cardLockCb();
  } else {
    alert('❌ Wrong OTP.');
  }
}

/* ── Face Lock ── */
function clFaceSetOpen(){
  document.getElementById('clFaceBar').style.width='0%';
  document.getElementById('clFaceStatus').textContent='Camera starting…';
  document.getElementById('clFaceCapBtn').disabled=true;
  navigator.mediaDevices.getUserMedia({video:{facingMode:'user',width:240,height:240}})
    .then(stream=>{
      _clStream=stream;
      const v=document.getElementById('clFaceVid');
      v.srcObject=stream;v.play();
      document.getElementById('clFaceStatus').textContent='Position face, then click Capture.';
      document.getElementById('clFaceCapBtn').disabled=false;
    })
    .catch(()=>{document.getElementById('clFaceStatus').textContent='Camera access denied.';});
  document.getElementById('clFaceSetDlg').classList.add('show');
}

async function clFaceCapture(){
  const vid=document.getElementById('clFaceVid');
  const status=document.getElementById('clFaceStatus');
  const bar=document.getElementById('clFaceBar');
  document.getElementById('clFaceOverlay').classList.add('scanning');
  status.textContent='Capturing…';
  const frames=[];
  for(let i=0;i<3;i++){bar.style.width=((i+1)/3*100)+'%';frames.push(captureFrame(vid));await sleep(300);}
  const avg=frames[0].map((_,j)=>frames.reduce((s,f)=>s+f[j],0)/frames.length);
  setCardLockData(cardLockKey,{method:'face',faceData:avg});
  document.getElementById('clFaceOverlay').classList.remove('scanning');
  status.textContent='✅ Registered! Card locked.';
  bar.style.width='100%';
  await sleep(700);
  clStopStream();
  closeDlg('clFaceSetDlg');
  if(cardLockCb)cardLockCb();
}

function clFaceUnlOpen(){
  document.getElementById('clFaceUnlBar').style.width='0%';
  document.getElementById('clFaceUnlStatus').textContent='Camera starting…';
  document.getElementById('clFaceUnlBtn').disabled=true;
  navigator.mediaDevices.getUserMedia({video:{facingMode:'user',width:240,height:240}})
    .then(stream=>{
      _clStream=stream;
      const v=document.getElementById('clFaceUnlVid');
      v.srcObject=stream;v.play();
      document.getElementById('clFaceUnlStatus').textContent='Look at camera, then click Scan.';
      document.getElementById('clFaceUnlBtn').disabled=false;
    })
    .catch(()=>{document.getElementById('clFaceUnlStatus').textContent='Camera access denied.';});
  document.getElementById('clFaceUnlDlg').classList.add('show');
}

async function clFaceScan(){
  const vid=document.getElementById('clFaceUnlVid');
  const status=document.getElementById('clFaceUnlStatus');
  const bar=document.getElementById('clFaceUnlBar');
  const data=getCardLockData(cardLockKey);
  if(!data||!data.faceData){status.textContent='No face registered.';return}
  document.getElementById('clFaceUnlOverlay').classList.add('scanning');
  status.textContent='Scanning…';
  const frames=[];
  for(let i=0;i<4;i++){bar.style.width=((i+1)/4*100)+'%';frames.push(captureFrame(vid));await sleep(250);}
  const avg=frames[0].map((_,j)=>frames.reduce((s,f)=>s+f[j],0)/frames.length);
  const sim=cosineSim(avg,data.faceData);
  document.getElementById('clFaceUnlOverlay').classList.remove('scanning');
  if(sim>0.92){
    status.textContent='✅ Matched! Unlocking…';
    bar.style.width='100%';
    await sleep(600);
    clStopStream();
    closeDlg('clFaceUnlDlg');
    setCardLockData(cardLockKey,null);
    if(cardLockCb)cardLockCb();
  } else {
    status.textContent='❌ Not recognised ('+Math.round(sim*100)+'% match). Try again.';
    bar.style.width='0%';
  }
}

function clFaceCancel(mode){
  clStopStream();
  closeDlg(mode==='set'?'clFaceSetDlg':'clFaceUnlDlg');
}
function clStopStream(){
  if(_clStream){_clStream.getTracks().forEach(t=>t.stop());_clStream=null;}
}

/* ── Open Unlock Dialog ── */
function openCardUnlock(key,cb){
  cardLockKey=key; cardLockCb=cb;
  const data=getCardLockData(key);
  if(!data){setCardLockData(key,null);cb();return} // stale lock
  const method=data.method||'pwd';
  if(method==='pwd'){
    document.getElementById('clTitle').textContent='🔓 Unlock Card';
    document.getElementById('clBody').innerHTML=`
      <input type="password" id="clUnPw" placeholder="Enter password" style="margin-top:6px">
      <div class="dlg-row" style="justify-content:space-between;flex-wrap:wrap;gap:8px">
        <button class="btn-link" onclick="clResetCardLock()">Remove lock</button>
        <div style="display:flex;gap:8px">
          <button class="btn-c" onclick="closeDlg('cardLockDlg')">Cancel</button>
          <button class="btn-p" onclick="doCardUnlock()">🔓 Unlock</button>
        </div>
      </div>`;
    document.getElementById('cardLockDlg').classList.add('show');
  } else if(method==='otp'){
    document.getElementById('clOtpMsg').textContent='Sending OTP…';
    document.getElementById('clOtpUnlDlg').classList.add('show');
    clSendOtp();
  } else if(method==='face'){
    clFaceUnlOpen();
  }
}

async function doCardUnlock(){
  const p=document.getElementById('clUnPw')?.value||'';
  const h=await sha256(p);
  const data=getCardLockData(cardLockKey);
  if(data&&h===data.hash){
    setCardLockData(cardLockKey,null);
    closeDlg('cardLockDlg');
    if(cardLockCb)cardLockCb();
  } else {
    document.getElementById('clUnPw').value='';
    alert('❌ Wrong password.');
  }
}

function clResetCardLock(){
  if(!confirm('Remove this card lock completely?'))return;
  clStopStream();
  ['cardLockDlg','clOtpUnlDlg','clFaceUnlDlg'].forEach(id=>{
    const el=document.getElementById(id);
    if(el.classList.contains('show'))closeDlg(id);
  });
  setCardLockData(cardLockKey,null);
  if(cardLockCb)cardLockCb();
}

