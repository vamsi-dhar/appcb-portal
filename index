    body.innerHTML=`<div class="section-hd">Lands &amp; Buildings — ${_panelRO}</div>
      <div style="font-size:12px;color:var(--smoke);margin-bottom:10px;line-height:1.6">Chronological details: acquisition, construction, survey nos., ownership, litigation status…</div>
      <textarea class="editable-area" id="editTA" placeholder="e.g.&#10;• 1985 — 500 sq.yd acquired (Survey No. 123)&#10;• 1990 — Construction completed&#10;• 2015 — Court case filed (pending)">${saved}</textarea>
      <div class="save-row"><div class="saved-notice" id="savedNote">✓ Saved</div><button class="save-btn" onclick="saveTab('lands')">💾 Save</button></div>`;
